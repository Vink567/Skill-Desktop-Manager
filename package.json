{
  "name": "skill-desktop-manager",
  "version": "0.2.0",
  "description": "Desktop manager for Codex and Claude Code skills.",
  "private": true,
  "author": "Vink567",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run dist:win",
    "dist:win": "npm run build && electron-builder --win nsis --publish never --config.electronDist=node_modules/electron/dist",
    "dist:win:ci": "npm run build && electron-builder --win nsis --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "preview": "electron-vite preview",
    "smoke": "npm run build && node scripts/smoke-electron.mjs",
    "smoke:packaged": "node scripts/smoke-packaged.mjs",
    "screenshot": "npm run build && node scripts/capture-screenshot.mjs",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.skilldesktop.manager",
    "productName": "Skill Desktop Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Skill Desktop Manager"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron-updater": "^6.6.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
